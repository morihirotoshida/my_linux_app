import 'dart:io';
import 'dart:convert';
import 'dart:typed_data';
import 'package:flutter/material.dart';
import 'package:flutter/services.dart';

import 'package:xterm/xterm.dart';
import 'package:flutter_pty/flutter_pty.dart';
import 'package:window_manager/window_manager.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  await windowManager.ensureInitialized();
  runApp(const MyApp());
}

class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      theme: ThemeData(
        brightness: Brightness.dark,
        primarySwatch: Colors.blue,
        scaffoldBackgroundColor: const Color(0xFF1E1E1E),
      ),
      home: const MyCustomUI(),
      debugShowCheckedModeBanner: false,
    );
  }
}

class FuncKeyIntent extends Intent {
  final String label;
  const FuncKeyIntent(this.label);
}

class MyCustomUI extends StatefulWidget {
  const MyCustomUI({super.key});

  @override
  State<MyCustomUI> createState() => _MyCustomUIState();
}

// 状態保持用のグローバル変数
int _launcherIndex = -1;
String? _registeredAppName;
String? _registeredCommand;

class _MyCustomUIState extends State<MyCustomUI> {
  final GlobalKey<PopupMenuButtonState<String>> _menuKey = GlobalKey();
  final FocusNode _menuFocusNode = FocusNode();

  String _lastPressed = "キーボードの矢印キーで移動できます";
  String _currentSelection = "";

  final List<Map<String, dynamic>> _openWindows = [];
  static const double _buttonHeight = 32.0;

  // --- ウィンドウ操作系メソッド群 ---
  void _openTerminalWindow() {
    Terminal terminal = Terminal();
    Pty pty = Pty.start('bash', arguments: ['-l'], environment: Platform.environment);
    FocusNode terminalFocus = FocusNode();
    terminalFocus.addListener(() { if (mounted) setState(() {}); });
    pty.output.listen((data) => terminal.write(utf8.decode(data, allowMalformed: true)));
    terminal.onOutput = (data) => pty.write(Uint8List.fromList(utf8.encode(data)));
    pty.exitCode.then((_) { if (mounted) setState(() => _openWindows.removeWhere((win) => win['pty'] == pty)); });

    _addWindowToMDI(title: 'ターミナル (bash)', focusNode: terminalFocus, content: TerminalView(terminal, focusNode: terminalFocus), extraData: {'pty': pty});
  }

  void _openAppLauncherWindow() {
    FocusNode launcherFocus = FocusNode();
    launcherFocus.addListener(() { if (mounted) setState(() {}); });
    _addWindowToMDI(
      title: 'アプリ・メニュー',
      focusNode: launcherFocus,
      width: 350.0,
      height: 450.0,
      content: StatefulBuilder(
        builder: (context, setWinState) {
          return Container(
            color: const Color(0xFF2C2C2C),
            child: ListView(
              children: [
                _buildAppLaunchTile(0, 'テキストエディター', 'gnome-text-editor', setWinState),
                _buildAppLaunchTile(1, '電卓', 'gnome-calculator', setWinState),
                _buildAppLaunchTile(2, 'システムモニター', 'gnome-system-monitor', setWinState),
                _buildAppLaunchTile(3, 'ファイルマネージャー', 'nautilus', setWinState),
                _buildAppLaunchTile(4, '設定', 'gnome-control-center', setWinState),
                _buildAppLaunchTile(5, 'Firefox ブラウザ', 'firefox', setWinState),
              ],
            ),
          );
        },
      ),
    );
  }

  void _addWindowToMDI({required String title, required FocusNode focusNode, required Widget content, double width = 500.0, double height = 350.0, Map<String, dynamic>? extraData}) {
    setState(() {
      _openWindows.add({
        'id': DateTime.now().toString(),
        'title': title,
        'content': content,
        'focusNode': focusNode,
        'x': 50.0 + (_openWindows.length * 20),
        'y': 50.0 + (_openWindows.length * 20),
        'width': width,
        'height': height,
        'isMaximized': true,
        'isMinimized': false,
        ...?extraData,
      });
    });
  }

  Widget _buildAppLaunchTile(int index, String name, String command, StateSetter setWinState) {
    bool isSelected = (_launcherIndex == index);
    return Focus(
      onFocusChange: (hasFocus) { if (hasFocus) { setState(() => _launcherIndex = index); setWinState(() {}); } },
      child: FocusableActionDetector(
        child: InkWell(
          onTap: () { setState(() => _launcherIndex = index); setWinState(() {}); Process.start(command, []); },
          child: Container(
            color: isSelected ? Colors.white10 : Colors.transparent,
            child: ListTile(
              leading: Icon(Icons.rocket_launch, color: isSelected ? Colors.yellow : Colors.blueAccent),
              title: Text(name, style: TextStyle(color: isSelected ? Colors.yellow : Colors.white, fontSize: 14)),
              trailing: isSelected ? ElevatedButton(
                style: ElevatedButton.styleFrom(backgroundColor: Colors.blueAccent, foregroundColor: Colors.white, textStyle: const TextStyle(fontSize: 10)),
                onPressed: () { setState(() { _registeredAppName = name; _registeredCommand = command; _lastPressed = "$name をF1ショートカットに登録しました"; }); },
                child: const Text("アプリを登録"),
              ) : null,
            ),
          ),
        ),
      ),
    );
  }

  // --- キー入力処理 ---
  void _handleAction(String label) {
    setState(() {
      _lastPressed = "$label が押されました";
      _currentSelection = label;
    });

    if (label == 'F1') {
      if (_registeredAppName != null) {
        // メッセージ更新（Enter/Space起動待ち）
        setState(() => _lastPressed = "${_registeredAppName}を起動 (Enter/Spaceで実行)");
      } else {
        _openAppLauncherWindow();
      }
    }
    if (label == 'ESC') _menuFocusNode.requestFocus();
  }

  // --- UI構築用 ---
  Widget _buildWindowControlButton(IconData icon, double orderValue, VoidCallback onPressed, {Color? defaultBgColor}) {
    return FocusTraversalOrder(
      order: NumericFocusOrder(orderValue),
      child: Padding(
        padding: const EdgeInsets.only(left: 4.0),
        child: SizedBox(
          width: 28, height: 24,
          child: ElevatedButton(
            onPressed: onPressed,
            style: ButtonStyle(
              backgroundColor: WidgetStateProperty.resolveWith<Color>((states) => states.contains(WidgetState.focused) ? Colors.yellow : defaultBgColor ?? Colors.grey[700]!),
              foregroundColor: WidgetStateProperty.resolveWith<Color>((states) => states.contains(WidgetState.focused) ? Colors.black : Colors.white),
              padding: WidgetStateProperty.all(EdgeInsets.zero),
              shape: WidgetStateProperty.all(const RoundedRectangleBorder()),
            ),
            child: Icon(icon, size: 16),
          ),
        ),
      ),
    );
  }

  Widget _buildFloatingWindow(int index, BoxConstraints constraints) {
    var win = _openWindows[index];
    bool isMinimized = win['isMinimized'];
    bool isMaximized = win['isMaximized'];
    double baseOrder = (index + 1) * 10.0;
    return Container(
      decoration: BoxDecoration(color: Colors.black, border: Border.all(color: Colors.grey[600]!, width: 2)),
      child: Column(
        children: [
          Container(
            color: Colors.blue[900],
            height: 30,
            child: Row(
              children: [
                Expanded(child: Padding(padding: const EdgeInsets.only(left: 8), child: Text(win['title'], style: const TextStyle(fontSize: 12, fontWeight: FontWeight.bold)))),
                _buildWindowControlButton(Icons.remove, baseOrder + 0.1, () => setState(() => win['isMinimized'] = !isMinimized)),
                _buildWindowControlButton(isMaximized ? Icons.filter_none : Icons.crop_square, baseOrder + 0.2, () => setState(() => win['isMaximized'] = !isMaximized)),
                _buildWindowControlButton(Icons.close, baseOrder + 0.3, () { setState(() { if (win['pty'] != null) (win['pty'] as Pty).kill(); _openWindows.removeAt(index); }); }, defaultBgColor: Colors.red[700]),
              ],
            ),
          ),
          if (!isMinimized) Expanded(child: FocusTraversalOrder(order: NumericFocusOrder(baseOrder + 0.4), child: Container(decoration: BoxDecoration(border: Border.all(color: (win['focusNode'] as FocusNode).hasFocus ? Colors.yellow : Colors.transparent, width: 2)), child: win['content']))),
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Shortcuts(
      shortcuts: <ShortcutActivator, Intent>{
        LogicalKeySet(LogicalKeyboardKey.escape): const FuncKeyIntent('ESC'),
        LogicalKeySet(LogicalKeyboardKey.enter): const FuncKeyIntent('Enter'),
        LogicalKeySet(LogicalKeyboardKey.space): const FuncKeyIntent('Space'),
        for (var i = 1; i <= 12; i++) LogicalKeySet(LogicalKeyboardKey(0x110000000 + i)): FuncKeyIntent('F$i'),
      },
      child: Actions(
        actions: <Type, Action<Intent>>{
          FuncKeyIntent: CallbackAction<FuncKeyIntent>(onInvoke: (intent) {
            // ★ 特殊処理：F1登録アプリが待機中で、Enter または Space が押された場合
            if ((intent.label == 'Enter' || intent.label == 'Space') && _registeredCommand != null && _currentSelection == "F1") {
              Process.start(_registeredCommand!, []);
              setState(() => _lastPressed = "${_registeredAppName}を起動しました");
              return null;
            }
            _handleAction(intent.label);
            return null;
          })
        },
        child: Scaffold(
          body: FocusTraversalGroup(
            policy: OrderedTraversalPolicy(),
            child: Column(
              children: [
                Expanded(
                  child: Container(
                    margin: const EdgeInsets.all(8),
                    decoration: BoxDecoration(color: Colors.black, border: Border.all(color: Colors.grey[700]!, width: 2)),
                    child: LayoutBuilder(builder: (context, constraints) {
                      return Stack(
                        children: [
                          // ★ MDI背景のインジケーター表示
                          Center(
                            child: Column(
                              mainAxisAlignment: MainAxisAlignment.center,
                              children: [
                                // F1にフォーカスがある時に登録情報を表示
                                if (_currentSelection == "F1" && _registeredAppName != null) ...[
                                  const Icon(Icons.rocket_launch, color: Colors.yellow, size: 64),
                                  const SizedBox(height: 16),
                                  Text(
                                    "「$_registeredAppName」が登録されています",
                                    style: const TextStyle(color: Colors.yellow, fontSize: 24, fontWeight: FontWeight.bold, fontFamily: 'monospace'),
                                  ),
                                  const SizedBox(height: 8),
                                  const Text("Enter または Space で起動", style: TextStyle(color: Colors.grey, fontSize: 16)),
                                ] else ...[
                                  Text(_lastPressed, style: const TextStyle(color: Colors.greenAccent, fontFamily: 'monospace', fontSize: 18)),
                                ]
                              ],
                            ),
                          ),
                          for (int i = 0; i < _openWindows.length; i++)
                            Positioned(
                              left: _openWindows[i]['isMaximized'] ? 0 : _openWindows[i]['x'],
                              top: _openWindows[i]['isMaximized'] ? 0 : _openWindows[i]['y'],
                              width: _openWindows[i]['isMaximized'] ? constraints.maxWidth : _openWindows[i]['width'],
                              height: _openWindows[i]['isMinimized'] ? 34.0 : (_openWindows[i]['isMaximized'] ? constraints.maxHeight : _openWindows[i]['height']),
                              child: _buildFloatingWindow(i, constraints),
                            ),
                        ],
                      );
                    }),
                  ),
                ),
                // --- 下部メニューバー ---
                Container(
                  color: Colors.black87,
                  padding: const EdgeInsets.symmetric(vertical: 8.0, horizontal: 4.0),
                  child: Row(
                    children: [
                      _buildMenuButton(),
                      ...List.generate(12, (index) => _buildKeyButton("F${index + 1}", 1.0 + ((index + 1) * 0.01))),
                      _buildKeyButton("ESC", 1.13, defaultColor: Colors.red[900]),
                    ],
                  ),
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }

  // ■ メニューボタンの構築（リファクタリング）
  Widget _buildMenuButton() {
    return FocusTraversalOrder(
      order: const NumericFocusOrder(1.0),
      child: SizedBox(
        width: _buttonHeight, height: _buttonHeight,
        child: Focus(
          focusNode: _menuFocusNode,
          onKeyEvent: (node, event) {
            if (event is KeyDownEvent && (event.logicalKey == LogicalKeyboardKey.enter || event.logicalKey == LogicalKeyboardKey.space)) {
              _handleShowMenu(); return KeyEventResult.handled;
            }
            return KeyEventResult.ignored;
          },
          onFocusChange: (hasFocus) { if (hasFocus) setState(() => _currentSelection = "Menu"); },
          child: GestureDetector(
            onTap: _handleShowMenu,
            child: Container(
              key: _menuKey,
              decoration: BoxDecoration(color: _currentSelection == "Menu" ? Colors.yellow : Colors.transparent, shape: BoxShape.circle),
              child: Center(child: Icon(Icons.square, color: _currentSelection == "Menu" ? Colors.black : Colors.white, size: 20)),
            ),
          ),
        ),
      ),
    );
  }

  Widget _buildKeyButton(String label, double orderValue, {Color? defaultColor}) {
    bool isSelected = _currentSelection == label;
    bool isEsc = label == "ESC";
    return Expanded(
      child: Padding(
        padding: const EdgeInsets.symmetric(horizontal: 2.0),
        child: FocusTraversalOrder(
          order: NumericFocusOrder(orderValue),
          child: SizedBox(
            height: _buttonHeight,
            child: ElevatedButton(
              onFocusChange: (hasFocus) { if (hasFocus) setState(() { _currentSelection = label; }); },
              style: ElevatedButton.styleFrom(
                padding: EdgeInsets.zero,
                backgroundColor: (isSelected && !isEsc) ? Colors.yellow : (defaultColor ?? Colors.grey[800]),
                foregroundColor: (isSelected && !isEsc) ? Colors.black : Colors.white,
                shape: RoundedRectangleBorder(borderRadius: isEsc ? BorderRadius.circular(4) : const BorderRadius.only(bottomLeft: Radius.circular(4), bottomRight: Radius.circular(4))),
              ),
              onPressed: () => _handleAction(label),
              child: Text(label, style: const TextStyle(fontSize: 10, fontWeight: FontWeight.bold)),
            ),
          ),
        ),
      ),
    );
  }

  void _handleShowMenu() {
    setState(() => _currentSelection = "Menu");
    final RenderBox renderBox = _menuKey.currentContext?.findRenderObject() as RenderBox;
    final Offset offset = renderBox.localToGlobal(Offset.zero);
    showMenu<String>(
      context: context,
      position: RelativeRect.fromLTRB(offset.dx, offset.dy - 256, offset.dx + renderBox.size.width, offset.dy),
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(8), side: BorderSide(color: Colors.grey[700]!, width: 1)),
      items: [
        const PopupMenuItem(value: 'exit', child: ListTile(leading: Icon(Icons.exit_to_app, color: Colors.red, size: 20), title: Text('終了'), dense: true)),
        const PopupMenuDivider(),
        const PopupMenuItem(value: 'sys_info', child: ListTile(leading: Icon(Icons.computer, size: 20), title: Text('システム情報'), dense: true)),
        const PopupMenuDivider(),
        // ★ 最大化/復元の選択肢を追加
        const PopupMenuItem(value: 'maximize', child: ListTile(leading: Icon(Icons.fullscreen, size: 20), title: Text('ウインドウの最大化/復元'), dense: true)),
        const PopupMenuItem(value: 'terminal', child: ListTile(leading: Icon(Icons.terminal, size: 20), title: Text('ターミナル'), dense: true)),
      ],
    ).then((value) { if (value != null) _handleMenuAction(value); setState(() => _currentSelection = ""); });
  }

  void _handleMenuAction(String value) {
    if (value == 'terminal') _openTerminalWindow();
    if (value == 'exit') exit(0);
  }
}